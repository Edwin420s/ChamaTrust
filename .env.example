# ChamaTrust Environment Configuration Template
# Copy this file to .env and update with your actual values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port the server will run on
PORT=5000

# Environment mode (development, staging, production)
NODE_ENV=development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://postgres:password@localhost:5432/chamatrust"

# Database connection pool size (optional)
DATABASE_POOL_SIZE=10

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT secret key (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT token expiration time
# Format: number + unit (s, m, h, d)
JWT_EXPIRES_IN=7d

# Encryption key for sensitive data (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-character-hex-encryption-key-here

# Session secret
SESSION_SECRET=your-session-secret-key-change-this

# =============================================================================
# GOOGLE OAUTH CONFIGURATION
# =============================================================================

# Google OAuth 2.0 Client ID
# Get from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth 2.0 Client Secret
# Get from: https://console.developers.google.com/
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth callback URL
# Update this based on your deployment URL
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Google OAuth scope
GOOGLE_SCOPE=profile email

# =============================================================================
# STELLAR BLOCKCHAIN CONFIGURATION
# =============================================================================

# Stellar network (testnet, public, futurenet)
STELLAR_NETWORK=testnet

# Stellar Horizon API URL
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar Friendbot URL (for testnet funding)
FRIENDBOT_URL=https://friendbot.stellar.org

# Stellar network passphrase (for mainnet)
STELLAR_NETWORK_PASSPHRASE=your-stellar-network-passphrase

# Default base fee for Stellar transactions (in stroops)
STELLAR_BASE_FEE=100

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email service provider (sendgrid, ses, mailgun, etc.)
EMAIL_SERVICE=sendgrid

# Email API key
EMAIL_API_KEY=your-email-service-api-key

# From email address
EMAIL_FROM=noreply@chamatrust.com

# Email from name
EMAIL_FROM_NAME=ChamaTrust

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================

# General API rate limit (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Authentication rate limit (login attempts)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log file path (optional)
LOG_FILE_PATH=./logs/app.log

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================

# Redis connection string (for session storage, caching)
REDIS_URL=redis://localhost:6379

# Redis key prefix
REDIS_KEY_PREFIX=chamatrust:

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend build mode (development, production)
VITE_BUILD_MODE=development

# API base URL
VITE_API_URL=http://localhost:5000

# App name and version
VITE_APP_NAME=ChamaTrust
VITE_APP_VERSION=1.0.0

# Google OAuth client ID (for frontend)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Application monitoring (sentry, datadog, etc.)
MONITORING_SERVICE=sentry

# Monitoring DSN/key
MONITORING_DSN=your-monitoring-dsn

# Performance monitoring
PERFORMANCE_MONITORING_ENABLED=true

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable debug mode (shows detailed error information)
DEBUG_MODE=true

# Enable hot reload (development only)
HOT_RELOAD=true

# Mock external services (development only)
MOCK_EXTERNAL_APIS=true

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Enable CORS (production)
CORS_ORIGIN=https://yourdomain.com

# Enable HTTPS (production)
FORCE_HTTPS=true

# SSL certificate path
SSL_CERT_PATH=/path/to/certificate.crt

# SSL private key path
SSL_KEY_PATH=/path/to/private.key

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Database backup schedule (cron format)
DB_BACKUP_SCHEDULE=0 2 * * *

# Backup retention period (days)
BACKUP_RETENTION_DAYS=30

# Backup storage path
BACKUP_STORAGE_PATH=./backups/

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Test database URL
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/chamatrust_test"

# Test JWT secret
TEST_JWT_SECRET=test-jwt-secret-key-for-testing-only

# Test encryption key
TEST_ENCRYPTION_KEY=1234567890abcdef1234567890abcdef

# =============================================================================
# ADDITIONAL SERVICES
# =============================================================================

# M-Pesa integration (optional)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=123456

# File upload service (aws s3, cloudinary, etc.)
FILE_UPLOAD_SERVICE=aws-s3
FILE_UPLOAD_BUCKET=chamatrust-uploads
FILE_UPLOAD_REGION=us-east-1
FILE_UPLOAD_ACCESS_KEY=your-aws-access-key
FILE_UPLOAD_SECRET_KEY=your-aws-secret-key

# =============================================================================
# SECURITY NOTES
# =============================================================================

# IMPORTANT SECURITY REMINDERS:
# 1. Never commit this file with real credentials to version control
# 2. Use strong, unique secrets in production
# 3. Rotate secrets regularly (recommended every 90 days)
# 4. Use environment-specific configurations
# 5. Enable all security features in production
# 6. Monitor for unauthorized access attempts
