# =============================================================================
# CHAMATRUST FRONTEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update with your actual values
# Never commit .env with real credentials to version control

# =============================================================================
# VITE CONFIGURATION
# =============================================================================

# API base URL for backend communication
VITE_API_URL=http://localhost:5000

# Application name
VITE_APP_NAME=ChamaTrust

# Application version
VITE_APP_VERSION=1.0.0

# Build mode (development, production)
VITE_BUILD_MODE=development

# =============================================================================
# GOOGLE OAUTH CONFIGURATION
# =============================================================================

# Google OAuth 2.0 Client ID (for frontend)
# Get from: https://console.developers.google.com/
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth callback URL (frontend)
VITE_GOOGLE_CALLBACK_URL=http://localhost:5173/auth/callback

# =============================================================================
# STYLING CONFIGURATION
# =============================================================================

# Tailwind CSS configuration
VITE_TAILWIND_CONFIG=true

# CSS framework (tailwind, bootstrap, etc.)
VITE_CSS_FRAMEWORK=tailwind

# =============================================================================
# API CONFIGURATION
# =============================================================================

# API timeout in milliseconds
VITE_API_TIMEOUT=10000

# API retry attempts
VITE_API_RETRY_ATTEMPTS=3

# Enable mock data for development
VITE_MOCK_API=false

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================

# Google Analytics tracking ID (optional)
VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# Sentry error tracking DSN (optional)
VITE_SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable debug mode (shows detailed error information)
VITE_DEBUG_MODE=true

# Enable hot reload (development only)
VITE_HOT_RELOAD=true

# Enable performance monitoring
VITE_PERFORMANCE_MONITORING=true

# =============================================================================
# UI CONFIGURATION
# =============================================================================

# Application theme (light, dark, auto)
VITE_THEME=auto

# Default language
VITE_DEFAULT_LANGUAGE=en

# Currency display format (KES, USD, etc.)
VITE_CURRENCY=KES

# Date format (DD/MM/YYYY, MM/DD/YYYY, etc.)
VITE_DATE_FORMAT=DD/MM/YYYY

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable development tools
VITE_DEV_TOOLS=true

# Show component boundaries (development)
VITE_SHOW_BOUNDARIES=true

# Enable strict mode checks
VITE_STRICT_MODE=false

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Base URL for production
VITE_BASE_URL=https://yourdomain.com

# CDN URL for static assets (optional)
VITE_CDN_URL=https://cdn.yourdomain.com

# Enable service worker
VITE_ENABLE_SERVICE_WORKER=true

# Cache version for assets
VITE_CACHE_VERSION=1.0.0

# =============================================================================
# SECURITY NOTES
# =============================================================================

# IMPORTANT SECURITY REMINDERS:
# 1. Never commit this file with real credentials to version control
# 2. Use environment-specific configurations
# 3. In production, use HTTPS URLs only
# 4. Validate all user inputs on frontend
# 5. Enable CSP headers in production
# 6. Monitor for XSS and injection attacks
