generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  password         String?
  name             String
  trustScore       Float     @default(0.0)
  stellarPublicKey String?   @map("stellar_public_key")
  stellarSecretKey String?   @map("stellar_secret_key")
  role             String    @default("user") // user, admin
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt

  loans            Loan[]
  transactions     Transaction[]
  disputes         Dispute[]

  @@map("users")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  amount      Float
  type        String   // contribution, loan_disbursement, loan_repayment, penalty
  status      String   @default("pending") // pending, completed, failed
  stellarTxHash String? @map("stellar_tx_hash")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model Loan {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  amount           Float
  interestRate     Float     @default(0.0) @map("interest_rate")
  appliedDate      DateTime  @default(now()) @map("applied_date")
  repaymentDeadline DateTime  @map("repayment_deadline")
  status           String    @default("pending") // pending, approved, rejected, active, repaid, defaulted, funding_failed
  riskScore        Float?    @map("risk_score")
  riskLevel        String?   @map("risk_level") // LOW, MEDIUM, HIGH
  guarantorIds     Int[]     @map("guarantor_ids")
  stellarTxHash    String?   @map("stellar_tx_hash")
  purpose          String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id])

  @@map("loans")
}

model Dispute {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  title       String
  description String
  evidenceUrl String?   @map("evidence_url")
  status      String    @default("open") // open, under_review, resolved, rejected
  resolution  String?
  resolvedBy  Int?      @map("resolved_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])

  @@map("disputes")
}